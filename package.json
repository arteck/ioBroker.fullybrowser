{
  "name": "iobroker.fullybrowser",
  "version": "3.1.3",
  "description": "Manage yours Fully Browser",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arteck/ioBroker.fullybrowser.git"
  },
  "keywords": [
    "fullyBrowser",
    "Fully Browser",
    "Android",
    "ioBroker"
  ],
  "author": {
    "name": "Arthur Rupp",
    "email": "arteck@outlook.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/arteck/ioBroker.fullybrowser/issues"
  },
  "homepage": "https://github.com/arteck/ioBroker.fullybrowser#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "@iobroker/dm-utils": "^3.0.3",
    "aedes": "^1.0.1",
    "axios": "^1.13.6",
    "net": "^1.0.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/testing": "^5.2.2",
    "@iobroker/eslint-config": "^2.2.0",
    "@tsconfig/node14": "^14.1.8",
    "@types/node": "^25.5.0",
    "@types/node-schedule": "^2.1.8",
    "typescript": "~6.0.2"
  },
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint .",
    "translate": "translate-adapter",
    "release": "release-script",
    "release-patch": "release-script patch --yes",
    "release-minor": "release-script minor --yes",
    "release-major": "release-script major --yes"
  },
  "readmeFilename": "README.md"
}
